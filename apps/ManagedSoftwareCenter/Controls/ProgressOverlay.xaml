<?xml version="1.0" encoding="utf-8"?>
<!-- ProgressOverlay.xaml - Installation Progress Overlay Control (WPF/ModernWpf) -->
<UserControl
    x:Class="Cimian.GUI.ManagedSoftwareCenter.Controls.ProgressOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.modernwpf.com/2019"
    mc:Ignorable="d">

    <!-- Semi-transparent backdrop -->
    <Grid Background="{DynamicResource SmokeFillColorDefaultBrush}">
        
        <!-- Centered Progress Card -->
        <Border 
            Background="{DynamicResource AcrylicBackgroundFillColorBaseBrush}"
            CornerRadius="16"
            Padding="32"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            MinWidth="400"
            MaxWidth="500">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.3"/>
            </Border.Effect>
            
            <StackPanel>
                
                <!-- Header: Icon + Title -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,24">
                    <Border 
                        Width="48" Height="48" 
                        CornerRadius="12"
                        Background="{DynamicResource AccentFillColorDefaultBrush}">
                        <ui:FontIcon 
                            Glyph="&#xE896;" 
                            FontSize="24"
                            Foreground="White"/>
                    </Border>
                    <StackPanel VerticalAlignment="Center" Margin="16,0,0,0">
                        <TextBlock 
                            x:Name="CurrentItemNameText"
                            Text="Installing..."
                            Style="{StaticResource SubtitleTextBlockStyle}"
                            MaxWidth="300"
                            TextTrimming="CharacterEllipsis"/>
                        <TextBlock 
                            x:Name="StatusMessageText"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Progress Bar -->
                <StackPanel Margin="0,0,0,24">
                    <ui:ProgressBar 
                        x:Name="MainProgress"
                        Height="8"/>
                    
                    <Grid Margin="0,8,0,0">
                        <TextBlock 
                            x:Name="ProgressText"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            HorizontalAlignment="Left"/>
                        <TextBlock 
                            x:Name="PercentText"
                            Style="{StaticResource CaptionTextBlockStyle}"
                            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                            HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>

                <!-- Detail Message (downloading, extracting, etc.) -->
                <Border 
                    x:Name="DetailMessageBorder"
                    Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,0,0,24"
                    Visibility="Collapsed">
                    <StackPanel>
                        <TextBlock 
                            x:Name="DetailMessageText"
                            Style="{StaticResource BodyTextBlockStyle}"
                            TextWrapping="Wrap"
                            MaxHeight="60"/>
                        
                        <!-- Download Speed / ETA -->
                        <StackPanel x:Name="DownloadStatsPanel" Orientation="Horizontal" Margin="0,8,0,0" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal">
                                <ui:FontIcon Glyph="&#xE896;" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                <TextBlock 
                                    x:Name="DownloadSpeedText"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    Margin="4,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="16,0,0,0">
                                <ui:FontIcon Glyph="&#xE823;" FontSize="12" Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                <TextBlock 
                                    x:Name="TimeRemainingText"
                                    Style="{StaticResource CaptionTextBlockStyle}"
                                    Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                    Margin="4,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Multi-item Progress (if installing multiple) -->
                <StackPanel 
                    x:Name="MultiItemProgressPanel"
                    Margin="0,0,0,24"
                    Visibility="Collapsed">
                    <TextBlock 
                        Text="Overall Progress"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                    <ui:ProgressBar 
                        x:Name="OverallProgress"
                        Height="4"
                        Margin="0,4,0,0"
                        Background="{DynamicResource ControlStrongFillColorDisabledBrush}"/>
                    <TextBlock 
                        x:Name="MultiItemStatusText"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Margin="0,4,0,0"/>
                </StackPanel>

                <!-- Action Buttons -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Hide Button -->
                    <Button 
                        x:Name="HideButton"
                        Grid.Column="0"
                        Content="Hide"
                        HorizontalAlignment="Left"
                        ToolTip="Continue in background"/>

                    <!-- Stop Button -->
                    <Button 
                        x:Name="StopButton"
                        Grid.Column="1"
                        Padding="16,8">
                        <StackPanel Orientation="Horizontal">
                            <ui:FontIcon Glyph="&#xE71A;" FontSize="14"/>
                            <TextBlock Text="Stop" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Button>
                </Grid>

            </StackPanel>
        </Border>
    </Grid>
</UserControl>
