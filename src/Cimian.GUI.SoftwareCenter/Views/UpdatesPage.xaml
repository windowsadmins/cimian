<?xml version="1.0" encoding="utf-8"?>
<!-- UpdatesPage.xaml - Pending Updates/Installs/Removals (Munki-style) -->
<Page
    x:Class="Cimian.GUI.SoftwareCenter.Views.UpdatesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.modernwpf.com/2019">

    <Grid>
        <!-- Main Content -->
        <ScrollViewer x:Name="MainContent" VerticalScrollBarVisibility="Auto" Padding="24">
            <StackPanel>
                
                <!-- Header Section with Status and Install Button -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="Updates" 
                                   Style="{StaticResource TitleTextBlockStyle}"/>
                        <TextBlock x:Name="StatusText"
                                   Text="Checking for updates..."
                                   Style="{StaticResource BodyTextBlockStyle}"
                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>

                    <!-- Big Install Now Button (Munki-style) -->
                    <Button x:Name="InstallNowButton"
                            Grid.Column="1"
                            Style="{StaticResource AccentButtonStyle}"
                            Click="InstallNow_Click"
                            MinWidth="140"
                            Height="44"
                            VerticalAlignment="Top">
                        <StackPanel Orientation="Horizontal">
                            <ui:FontIcon Glyph="&#xE896;" FontSize="16"/>
                            <TextBlock Text="Install Now" Margin="8,0,0,0" FontWeight="SemiBold"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Restart Required Warning -->
                <Border x:Name="RestartWarning"
                        Visibility="Collapsed"
                        Background="{DynamicResource SystemFillColorCautionBackgroundBrush}"
                        CornerRadius="8"
                        Padding="16"
                        Margin="0,0,0,16">
                    <StackPanel Orientation="Horizontal">
                        <ui:FontIcon Glyph="&#xE7BA;" FontSize="20" 
                                     Foreground="{DynamicResource SystemFillColorCautionBrush}"/>
                        <TextBlock Text="A restart will be required after installing these updates."
                                   Margin="12,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Pending Installs Section -->
                <StackPanel x:Name="PendingInstallsSection" Visibility="Collapsed">
                    <TextBlock Text="Pending Installs"
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               Margin="0,0,0,12"/>
                    <ItemsControl x:Name="PendingInstallsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="16"
                                        Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="48"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Icon -->
                                        <Border Grid.Column="0" 
                                                Width="40" Height="40" 
                                                CornerRadius="8"
                                                Background="{DynamicResource SystemFillColorSuccessBackgroundBrush}">
                                            <ui:FontIcon Glyph="&#xE710;" FontSize="18" 
                                                         Foreground="{DynamicResource SystemFillColorSuccessBrush}"/>
                                        </Border>

                                        <!-- Details -->
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName, FallbackValue='Unknown'}" 
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Version, StringFormat='Version {0}'}" 
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>

                                        <!-- Size -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" 
                                                    HorizontalAlignment="Right">
                                            <TextBlock Text="Will be installed"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource SystemFillColorSuccessBrush}"
                                                       HorizontalAlignment="Right"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Updates Section -->
                <StackPanel x:Name="UpdatesSection" Visibility="Collapsed" Margin="0,16,0,0">
                    <TextBlock Text="Available Updates"
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               Margin="0,0,0,12"/>
                    <ItemsControl x:Name="UpdatesList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="16"
                                        Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="48"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Icon -->
                                        <Border Grid.Column="0" 
                                                Width="40" Height="40" 
                                                CornerRadius="8"
                                                Background="{DynamicResource AccentFillColorDefaultBrush}">
                                            <ui:FontIcon Glyph="&#xE895;" FontSize="18" Foreground="White"/>
                                        </Border>

                                        <!-- Details -->
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName, FallbackValue='Unknown'}" 
                                                       FontWeight="SemiBold"/>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding InstalledVersion}" 
                                                           FontSize="12"
                                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                                <ui:FontIcon Glyph="&#xE72A;" FontSize="10"
                                                             Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                             Margin="8,2"/>
                                                <TextBlock Text="{Binding Version}" 
                                                           FontSize="12"
                                                           Foreground="{DynamicResource SystemFillColorSuccessBrush}"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Update Badge -->
                                        <Border Grid.Column="2" 
                                                VerticalAlignment="Center"
                                                Background="{DynamicResource AccentFillColorDefaultBrush}"
                                                CornerRadius="4"
                                                Padding="8,4">
                                            <TextBlock Text="Update" FontSize="11" Foreground="White"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Removals Section -->
                <StackPanel x:Name="RemovalsSection" Visibility="Collapsed" Margin="0,16,0,0">
                    <TextBlock Text="Pending Removals"
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               Margin="0,0,0,12"/>
                    <ItemsControl x:Name="RemovalsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource SystemFillColorCriticalBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Padding="16"
                                        Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="48"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Icon -->
                                        <Border Grid.Column="0" 
                                                Width="40" Height="40" 
                                                CornerRadius="8"
                                                Background="{DynamicResource SystemFillColorCriticalBackgroundBrush}">
                                            <ui:FontIcon Glyph="&#xE74D;" FontSize="18" 
                                                         Foreground="{DynamicResource SystemFillColorCriticalBrush}"/>
                                        </Border>

                                        <!-- Details -->
                                        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding DisplayName, FallbackValue='Unknown'}" 
                                                       FontWeight="SemiBold"/>
                                            <TextBlock Text="{Binding Version, StringFormat='Version {0}'}" 
                                                       FontSize="12"
                                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
                                        </StackPanel>

                                        <!-- Removal Badge -->
                                        <TextBlock Grid.Column="2" 
                                                   Text="Will be removed"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <!-- Problem Items Section -->
                <StackPanel x:Name="ProblemsSection" Visibility="Collapsed" Margin="0,16,0,0">
                    <TextBlock Text="Problem Items"
                               Style="{StaticResource SubtitleTextBlockStyle}"
                               Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                               Margin="0,0,0,12"/>
                    <ItemsControl x:Name="ProblemsList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource SystemFillColorCriticalBackgroundBrush}"
                                        CornerRadius="8"
                                        Padding="16"
                                        Margin="0,0,0,8">
                                    <StackPanel>
                                        <TextBlock Text="{Binding DisplayName, FallbackValue='Unknown'}" 
                                                   FontWeight="SemiBold"/>
                                        <TextBlock Text="{Binding ErrorMessage}" 
                                                   FontSize="12"
                                                   Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Empty State (All Up To Date) -->
        <StackPanel x:Name="EmptyState"
                    Visibility="Collapsed"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <ui:FontIcon Glyph="&#xE930;" FontSize="64"
                         Foreground="{DynamicResource SystemFillColorSuccessBrush}"/>
            <TextBlock Text="All software is up to date"
                       Style="{StaticResource SubtitleTextBlockStyle}"
                       HorizontalAlignment="Center"
                       Margin="0,16,0,4"/>
            <TextBlock Text="No pending updates, installs, or removals."
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Loading Indicator -->
        <ui:ProgressRing x:Name="LoadingIndicator"
                         IsActive="False"
                         Width="48" Height="48"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>

        <!-- Full-Page Progress View (during install/check) - takes over entire page -->
        <Grid x:Name="ProgressOverlay" 
              Visibility="Collapsed"
              Background="{DynamicResource ApplicationPageBackgroundThemeBrush}">
            
            <!-- Center the progress content -->
            <StackPanel HorizontalAlignment="Center" 
                        VerticalAlignment="Center"
                        Margin="48">
                
                <!-- Progress Ring -->
                <ui:ProgressRing x:Name="ProgressSpinner"
                                 IsActive="True"
                                 Width="80" Height="80"
                                 HorizontalAlignment="Center"/>
                
                <!-- Progress Message -->
                <TextBlock x:Name="ProgressMessageText"
                           Text="Checking for updates..."
                           FontSize="24"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Margin="0,32,0,0"/>
                
                <!-- Progress Detail -->
                <TextBlock x:Name="ProgressDetailText"
                           Text=""
                           FontSize="14"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           MaxWidth="500"
                           Margin="0,12,0,0"/>
                
                <!-- Progress Bar -->
                <ProgressBar x:Name="ProgressBar"
                             Minimum="0"
                             Maximum="100"
                             Value="0"
                             IsIndeterminate="True"
                             Width="400"
                             Margin="0,32,0,0"/>
                
                <!-- Percent Text -->
                <TextBlock x:Name="ProgressPercentText"
                           Text=""
                           FontSize="13"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0"/>
                
                <!-- Stop Button -->
                <Button x:Name="StopButton"
                        Content="Stop"
                        Click="StopButton_Click"
                        HorizontalAlignment="Center"
                        MinWidth="120"
                        Margin="0,32,0,0"
                        Visibility="Collapsed"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
