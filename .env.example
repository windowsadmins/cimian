# Cimian Build Configuration
# Copy this file to .env and update with your organization's values

# Enterprise Certificate Configuration
# Full certificate common name for reference
CIMIAN_CERT_CN=YourOrganization Enterprise Certificate

# Certificate subject pattern for auto-detection (partial match)
# This is used to find certificates in the certificate store
CIMIAN_CERT_SUBJECT=YourOrganization

# Optional: Override certificate thumbprint directly
# CIMIAN_CERT_THUMBPRINT=1234567890ABCDEF1234567890ABCDEF12345678

# Optional: Override certificate store location
# CIMIAN_CERT_STORE=CurrentUser
