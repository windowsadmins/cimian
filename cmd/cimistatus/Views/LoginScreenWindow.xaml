<Window x:Class="Cimian.Status.Views.LoginScreenWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Cimian System Configuration"
        Width="600"
        Height="400"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        ShowInTaskbar="False"
        Background="#1E1E1E">
    
    <Grid>
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="450">
            
            <!-- Title -->
            <TextBlock Text="Cimian System Configuration"
                       Foreground="White"
                       FontSize="28"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,40"/>
            
            <!-- Status Message -->
            <TextBlock x:Name="StatusText"
                       Text="Initializing..."
                       Foreground="#B0B0B0"
                       FontSize="16"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"
                       TextWrapping="Wrap"
                       TextAlignment="Center"/>
            
            <!-- Progress Bar -->
            <ProgressBar x:Name="ProgressBar"
                         Height="30"
                         Minimum="0"
                         Maximum="100"
                         Value="0"
                         Foreground="#0078D4"
                         Background="#3A3A3A"
                         BorderBrush="#555555"
                         BorderThickness="1"/>
            
            <!-- Detail Message -->
            <TextBlock x:Name="DetailText"
                       Text=""
                       Foreground="#808080"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       Margin="0,15,0,0"
                       TextWrapping="Wrap"
                       TextAlignment="Center"/>
            
        </StackPanel>
    </Grid>
</Window>
