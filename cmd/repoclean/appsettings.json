{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    },
    "Console": {
      "FormatterName": "simple",
      "FormatterOptions": {
        "SingleLine": true,
        "IncludeScopes": false,
        "TimestampFormat": "yyyy-MM-dd HH:mm:ss "
      }
    }
  },
  "RepoClean": {
    "DefaultKeepVersions": 2,
    "DefaultPlugin": "FileRepo",
    "ExcludePatterns": [
      "*.tmp",
      "*.temp",
      ".DS_Store",
      "Thumbs.db"
    ]
  }
}
