<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Cimian.GUI.ManagedSoftwareCenter.Views.SoftwarePage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:Cimian.GUI.ManagedSoftwareCenter.Converters">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <!-- Category Button Style (pill-shaped like Microsoft Store) -->
        <Style x:Key="CategoryPillButton" TargetType="Button">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="Margin" Value="4,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="16"
                                Padding="{TemplateBinding Padding}">
                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="ButtonBorder.Background" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="ButtonBorder.Background" Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        
        <!-- Selected Category Button Style -->
        <Style x:Key="CategoryPillButtonSelected" TargetType="Button" BasedOn="{StaticResource CategoryPillButton}">
            <Setter Property="Background" Value="{ThemeResource AccentFillColorDefaultBrush}" />
            <Setter Property="Foreground" Value="White" />
        </Style>
    </Page.Resources>

    <ScrollViewer x:Name="MainScrollViewer"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Hero Banner / Carousel (like Microsoft Store) -->
            <Grid Grid.Row="0" Height="220" Margin="24,16,24,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="160" />
                </Grid.ColumnDefinitions>

                <!-- Main banner with image carousel -->
                <Border x:Name="HeroBanner"
                        Grid.Column="0"
                        CornerRadius="12"
                        Margin="0,0,12,0">
                    <Grid>
                        <!-- Gradient background (fallback when no image) -->
                        <Border CornerRadius="12">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#1a5fb4" Offset="0"/>
                                    <GradientStop Color="#613583" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        
                        <!-- Carousel images container -->
                        <Grid x:Name="CarouselContainer">
                            <Image x:Name="BannerImage1" Stretch="UniformToFill" Opacity="1" />
                            <Image x:Name="BannerImage2" Stretch="UniformToFill" Opacity="0" />
                            <Image x:Name="BannerImage3" Stretch="UniformToFill" Opacity="0" />
                        </Grid>
                        
                        <!-- Banner content overlay -->
                        <StackPanel VerticalAlignment="Center" 
                                    HorizontalAlignment="Left"
                                    Margin="40,0,0,0">
                            <TextBlock Text="Managed Software Center" 
                                       FontSize="36" 
                                       FontWeight="SemiBold"
                                       Foreground="White" />
                        </StackPanel>
                        
                        <!-- Carousel indicators -->
                        <StackPanel x:Name="CarouselIndicators"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Bottom"
                                    Margin="0,0,0,16">
                            <Ellipse x:Name="Indicator1" Width="8" Height="8" Fill="White" Margin="4,0" Opacity="1" />
                            <Ellipse x:Name="Indicator2" Width="8" Height="8" Fill="White" Margin="4,0" Opacity="0.5" />
                            <Ellipse x:Name="Indicator3" Width="8" Height="8" Fill="White" Margin="4,0" Opacity="0.5" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Secondary promotional tiles (like Microsoft Store) -->
                <StackPanel Grid.Column="1">
                    <Border CornerRadius="8" Height="102"
                            Tapped="FeaturedButton_Click">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#26a269" Offset="0"/>
                                <GradientStop Color="#1c71d8" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel VerticalAlignment="Center" Margin="16">
                            <TextBlock Text="Featured" FontSize="14" FontWeight="SemiBold" Foreground="White" />
                            <TextBlock Text="Check out new apps" FontSize="11" Foreground="#B0FFFFFF" />
                        </StackPanel>
                    </Border>
                    <Border CornerRadius="8" Height="102" Margin="0,16,0,0"
                            Tapped="UpdatesButton_Click">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#e66100" Offset="0"/>
                                <GradientStop Color="#c64600" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel VerticalAlignment="Center" Margin="16">
                            <TextBlock Text="Updates" FontSize="14" FontWeight="SemiBold" Foreground="White" />
                            <TextBlock x:Name="UpdatesPromoText" Text="Keep apps current" FontSize="11" Foreground="#B0FFFFFF" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- Category Pills (like Microsoft Store) -->
            <ScrollViewer Grid.Row="1" 
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled"
                          Margin="24,20,24,0">
                <StackPanel x:Name="CategoryPillsPanel" Orientation="Horizontal" />
            </ScrollViewer>

            <!-- Search Bar -->
            <Grid Grid.Row="2" Margin="24,16,24,0">
                <AutoSuggestBox x:Name="SearchBox"
                                PlaceholderText="Search apps..."
                                QueryIcon="Find"
                                TextChanged="SearchBox_TextChanged"
                                HorizontalAlignment="Left"
                                Width="350" />
            </Grid>

            <!-- Section header -->
            <!-- Featured Items Section -->
            <StackPanel x:Name="FeaturedSection"
                        Grid.Row="3"
                        Visibility="Collapsed"
                        Margin="24,24,24,0">
                <TextBlock Text="Featured" 
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                           Margin="0,0,0,12" />
                <GridView x:Name="FeaturedGrid"
                          ItemsSource="{Binding FeaturedItems}"
                          IsItemClickEnabled="True"
                          ItemClick="OnItemClick"
                          SelectionMode="None">
                    <GridView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="8"
                                    Width="280" Height="100"
                                    Padding="12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" 
                                            Width="64" Height="64"
                                            CornerRadius="12"
                                            Background="{ThemeResource SubtleFillColorSecondaryBrush}"
                                            Margin="0,0,12,0">
                                        <Image Source="{Binding IconImage}"
                                               Width="64" Height="64"
                                               Stretch="UniformToFill" />
                                    </Border>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding DisplayName, FallbackValue='App Name'}" 
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{Binding Developer, FallbackValue=''}" 
                                                   FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   Margin="0,2,0,0" />
                                        <TextBlock Text="{Binding Description, FallbackValue=''}" 
                                                   FontSize="11"
                                                   Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxLines="2"
                                                   Margin="0,4,0,0" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </GridView.ItemTemplate>
                </GridView>
            </StackPanel>

            <!-- Section header -->
            <StackPanel Grid.Row="4" Margin="24,24,24,12" Orientation="Horizontal">
                <TextBlock x:Name="SectionHeader"
                           Text="All apps" 
                           FontSize="20"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                <TextBlock Text="›" 
                           FontSize="20"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Margin="8,0,0,0"
                           VerticalAlignment="Center" />
            </StackPanel>

            <!-- Loading indicator -->
            <ProgressRing x:Name="LoadingIndicator"
                          Grid.Row="5"
                          IsActive="False"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center" />

            <!-- Empty state -->
            <StackPanel x:Name="EmptyState"
                        Grid.Row="5"
                        Visibility="Collapsed"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Margin="0,60,0,0">
                <FontIcon Glyph="&#xE7B8;" FontSize="64" Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                <TextBlock x:Name="EmptyMessageText"
                           Text="No apps available"
                           FontSize="16"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,16,0,0" />
            </StackPanel>

            <!-- Software grid (Microsoft Store style tiles) -->
            <GridView x:Name="SoftwareGrid"
                      Grid.Row="5"
                      ItemsSource="{Binding Items}"
                      IsItemClickEnabled="True"
                      ItemClick="OnItemClick"
                      SelectionMode="None"
                      Margin="20,0,20,24"
                      MinHeight="200">
                <GridView.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Width="240" Height="140"
                                Padding="12">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- App Icon with status overlay -->
                                <Grid Grid.Row="0" Grid.Column="0" Width="48" Height="48" Margin="0,0,12,0" VerticalAlignment="Top">
                                    <Border CornerRadius="8"
                                            Background="{ThemeResource SubtleFillColorSecondaryBrush}">
                                        <Image Source="{Binding IconImage}"
                                               Width="48" Height="48"
                                               Stretch="UniformToFill" />
                                    </Border>
                                    <Border Width="16" Height="16"
                                            CornerRadius="8"
                                            Background="{ThemeResource SystemFillColorSuccessBrush}"
                                            HorizontalAlignment="Right"
                                            VerticalAlignment="Bottom"
                                            Margin="0,0,-2,-2"
                                            Visibility="{Binding Installed, Converter={StaticResource BoolToVisibilityConverter}}">
                                        <FontIcon Glyph="&#xE73E;" FontSize="9" Foreground="White"
                                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </Grid>

                                <!-- App Info -->
                                <StackPanel Grid.Row="0" Grid.Column="1" VerticalAlignment="Top">
                                    <TextBlock Text="{Binding DisplayName, FallbackValue='App Name'}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Developer, FallbackValue=''}"
                                               FontSize="11"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,2,0,0" />
                                    <TextBlock Text="{Binding StatusText, FallbackValue=''}"
                                               FontSize="11"
                                               Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                                               TextTrimming="CharacterEllipsis"
                                               Margin="0,4,0,0" />
                                </StackPanel>

                                <!-- Action buttons -->
                                <StackPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2"
                                            Orientation="Horizontal"
                                            Spacing="6"
                                            Margin="0,10,0,0">
                                    <Button Content="{Binding InstallActionLabel}"
                                            Style="{ThemeResource AccentButtonStyle}"
                                            Padding="12,4"
                                            FontSize="12"
                                            MinWidth="72"
                                            Visibility="{Binding ShowInstallAction, Converter={StaticResource BoolToVisibilityConverter}}"
                                            Command="{Binding ElementName=RootPage, Path=ViewModel.InstallItemCommand}"
                                            CommandParameter="{Binding}" />
                                    <Button Content="Remove"
                                            Padding="12,4"
                                            FontSize="12"
                                            MinWidth="72"
                                            Visibility="{Binding ShowRemoveAction, Converter={StaticResource BoolToVisibilityConverter}}"
                                            Command="{Binding ElementName=RootPage, Path=ViewModel.RemoveItemCommand}"
                                            CommandParameter="{Binding}" />
                                    <Button Content="Cancel"
                                            Padding="12,4"
                                            FontSize="12"
                                            MinWidth="72"
                                            Visibility="{Binding ShowCancelAction, Converter={StaticResource BoolToVisibilityConverter}}"
                                            Command="{Binding ElementName=RootPage, Path=ViewModel.CancelRequestCommand}"
                                            CommandParameter="{Binding}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </Grid>
    </ScrollViewer>
</Page>
