<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Cimian.GUI.ManagedSoftwareCenter.Views.CategoriesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.modernwpf.com/2019">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Text="Categories" 
                   Style="{StaticResource TitleTextBlockStyle}"
                   Margin="0,0,0,16" />

        <!-- Loading indicator -->
        <ui:ProgressRing x:Name="LoadingIndicator"
                      Grid.Row="1"
                      IsActive="False"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center" />

        <!-- Empty state -->
        <StackPanel x:Name="EmptyState"
                    Grid.Row="1"
                    Visibility="Collapsed"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
            <ui:FontIcon Glyph="&#xE8FD;" FontSize="48" Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
            <TextBlock Text="No categories available"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                       Margin="0,16,0,0" />
        </StackPanel>

        <!-- Categories list -->
        <ListView x:Name="CategoriesList"
                  Grid.Row="1"
                  SelectionMode="Single"
                  SelectionChanged="OnCategorySelectionChanged">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,8" Padding="16" 
                          Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                          CornerRadius="8"
                          BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                          BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Category header -->
                            <StackPanel Orientation="Horizontal" Grid.Row="0">
                                <TextBlock Text="{Binding Name}" 
                                           Style="{StaticResource SubtitleTextBlockStyle}" />
                                <TextBlock Text="{Binding ItemCount}" 
                                           Margin="8,0,0,0"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center" />
                                <TextBlock Text="items" 
                                           Margin="4,0,0,0"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center" />
                            </StackPanel>

                            <!-- Preview icons -->
                            <StackPanel Grid.Row="1" 
                                        Orientation="Horizontal" 
                                        Margin="0,12,0,0">
                                <Border Width="48" Height="48"
                                        CornerRadius="8"
                                        Background="{DynamicResource SubtleFillColorSecondaryBrush}">
                                    <ui:FontIcon Glyph="&#xE74C;" FontSize="24" 
                                              Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </Border>
                                <Border Width="48" Height="48"
                                        CornerRadius="8"
                                        Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                        Margin="12,0,0,0">
                                    <ui:FontIcon Glyph="&#xE74C;" FontSize="24" 
                                              Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </Border>
                                <Border Width="48" Height="48"
                                        CornerRadius="8"
                                        Background="{DynamicResource SubtleFillColorSecondaryBrush}"
                                        Margin="12,0,0,0">
                                    <ui:FontIcon Glyph="&#xE74C;" FontSize="24" 
                                              Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
    </Grid>
</Page>
