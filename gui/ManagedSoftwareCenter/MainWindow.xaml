<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Cimian.GUI.ManagedSoftwareCenter.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.modernwpf.com/2019"
    ui:WindowHelper.UseModernWindowStyle="True"
    Title="Managed Software Center"
    Width="1200"
    Height="800"
    MinWidth="800"
    MinHeight="600"
    WindowStartupLocation="CenterScreen">

    <Grid x:Name="RootGrid">
        <!-- Main Content with Navigation -->
        <ui:NavigationView x:Name="NavView"
                           IsBackButtonVisible="Collapsed"
                           IsSettingsVisible="False"
                           PaneDisplayMode="Left"
                           OpenPaneLength="200"
                           SelectionChanged="NavView_SelectionChanged"
                           Loaded="NavView_Loaded"
                           PaneOpening="NavView_PaneOpening"
                           PaneClosing="NavView_PaneClosing">
            
            <ui:NavigationView.MenuItems>
                <ui:NavigationViewItem Content="Software" Tag="software">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon Glyph="&#xE74C;" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                
                <ui:NavigationViewItem Content="Categories" Tag="categories">
                    <ui:NavigationViewItem.Icon>
                        <ui:FontIcon Glyph="&#xE8B7;" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                
                <ui:NavigationViewItem Content="My Items" Tag="myitems">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Favorite" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
                
                <ui:NavigationViewItem Content="Updates" Tag="updates">
                    <ui:NavigationViewItem.Icon>
                        <ui:SymbolIcon Symbol="Sync" />
                    </ui:NavigationViewItem.Icon>
                </ui:NavigationViewItem>
            </ui:NavigationView.MenuItems>

            <ui:NavigationView.PaneFooter>
                <StackPanel x:Name="PaneFooterContent" Margin="12,8">
                    <TextBlock x:Name="LastCheckedText"
                               FontSize="12"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               Margin="0,0,0,8" />
                    <Button x:Name="CheckNowButton"
                            Content="Check Now"
                            Click="CheckNow_Click"
                            HorizontalAlignment="Stretch" />
                </StackPanel>
            </ui:NavigationView.PaneFooter>

            <Grid>
                <!-- Page Content Frame -->
                <Frame x:Name="ContentFrame" NavigationUIVisibility="Hidden" />
            </Grid>
        </ui:NavigationView>
    </Grid>
</Window>

