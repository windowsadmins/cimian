<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Cimian.GUI.ManagedSoftwareCenter.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Managed Software Center">

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.KeyboardAccelerators>
            <KeyboardAccelerator Key="R" Modifiers="Control" Invoked="Refresh_Accelerator"/>
            <KeyboardAccelerator Key="F5" Invoked="Refresh_Accelerator"/>
            <KeyboardAccelerator Key="Left" Modifiers="Menu" Invoked="Back_Accelerator"/>
            <KeyboardAccelerator Key="L" Modifiers="Control" Invoked="ViewLog_Accelerator"/>
        </Grid.KeyboardAccelerators>

        <!-- Custom Title Bar -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="48"
              Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock x:Name="AppTitleText"
                       Grid.Column="0"
                       Text="Managed Software Center"
                       Style="{StaticResource CaptionTextBlockStyle}"
                       VerticalAlignment="Center"
                       Margin="16,0,0,0"/>
        </Grid>

        <!-- Main Content with Navigation -->
        <NavigationView x:Name="NavView"
                           Grid.Row="1"
                           IsBackButtonVisible="Collapsed"
                           IsSettingsVisible="False"
                           PaneDisplayMode="Left"
                           OpenPaneLength="200"
                           SelectionChanged="NavView_SelectionChanged"
                           Loaded="NavView_Loaded"
                           PaneOpening="NavView_PaneOpening"
                           PaneClosing="NavView_PaneClosing">

            <NavigationView.Resources>
                <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent" />
            </NavigationView.Resources>
            
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Software" Tag="software" AutomationProperties.Name="Software catalog">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE74C;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                
                <NavigationViewItem Content="Categories" Tag="categories" AutomationProperties.Name="Browse by category">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8B7;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                
                <NavigationViewItem Content="My Items" Tag="myitems" AutomationProperties.Name="My installed items">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Favorite" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                
                <NavigationViewItem Content="Updates" Tag="updates" AutomationProperties.Name="Available updates">
                    <NavigationViewItem.Icon>
                        <SymbolIcon Symbol="Sync" />
                    </NavigationViewItem.Icon>
                    <NavigationViewItem.InfoBadge>
                        <InfoBadge x:Name="UpdatesBadge" Value="0" Visibility="Collapsed" />
                    </NavigationViewItem.InfoBadge>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.PaneHeader>
                <Image x:Name="SidebarHeaderImage" 
                       Visibility="Collapsed"
                       Stretch="Uniform"
                       MaxHeight="80"
                       Margin="12,8" />
            </NavigationView.PaneHeader>

            <NavigationView.PaneFooter>
                <StackPanel x:Name="PaneFooterContent" Margin="12,8">
                    <TextBlock x:Name="LastCheckedText"
                               FontSize="12"
                               Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" />
                </StackPanel>
            </NavigationView.PaneFooter>

            <Grid>
                <!-- Page Content Frame -->
                <Frame x:Name="ContentFrame" />
            </Grid>
        </NavigationView>
    </Grid>
</Window>
