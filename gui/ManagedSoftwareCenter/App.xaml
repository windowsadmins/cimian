<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Cimian.GUI.ManagedSoftwareCenter.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.modernwpf.com/2019"
    StartupUri="MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemeResources />
                <ui:XamlControlsResources />
            </ResourceDictionary.MergedDictionaries>
            
            <!-- App-wide resources -->
            <system:String x:Key="AppName" xmlns:system="clr-namespace:System;assembly=mscorlib">Cimian Software Center</system:String>
            
            <!-- Text Fill Color Brushes (WinUI-compatible names mapped to ModernWpf resources) -->
            <SolidColorBrush x:Key="TextFillColorPrimaryBrush" Color="{DynamicResource SystemBaseHighColor}" />
            <SolidColorBrush x:Key="TextFillColorSecondaryBrush" Color="{DynamicResource SystemBaseMediumColor}" />
            <SolidColorBrush x:Key="TextFillColorTertiaryBrush" Color="{DynamicResource SystemBaseMediumLowColor}" />
            <SolidColorBrush x:Key="TextFillColorDisabledBrush" Color="{DynamicResource SystemBaseLowColor}" />
            <SolidColorBrush x:Key="AccentTextFillColorPrimaryBrush" Color="{DynamicResource SystemAccentColor}" />
            
            <!-- Status colors -->
            <SolidColorBrush x:Key="StatusAvailableBrush" Color="#107C10" />
            <SolidColorBrush x:Key="StatusInstalledBrush" Color="#0078D4" />
            <SolidColorBrush x:Key="StatusRequestedBrush" Color="#CA5010" />
            <SolidColorBrush x:Key="StatusUpdateBrush" Color="#8764B8" />
            <SolidColorBrush x:Key="StatusErrorBrush" Color="#D13438" />
        </ResourceDictionary>
    </Application.Resources>
</Application>

