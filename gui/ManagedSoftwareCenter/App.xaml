<?xml version="1.0" encoding="utf-8"?>
<Application
    x:Class="Cimian.GUI.ManagedSoftwareCenter.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <XamlControlsResources xmlns="using:Microsoft.UI.Xaml.Controls" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Soften dark mode background (match Terminal dark charcoal tone) -->
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="ApplicationPageBackgroundThemeBrush" Color="#1E1E2E" />
                    <SolidColorBrush x:Key="LayerFillColorDefaultBrush" Color="#252536" />
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>

            <!-- Status colors -->
            <SolidColorBrush x:Key="StatusAvailableBrush" Color="#107C10" />
            <SolidColorBrush x:Key="StatusInstalledBrush" Color="#0078D4" />
            <SolidColorBrush x:Key="StatusRequestedBrush" Color="#CA5010" />
            <SolidColorBrush x:Key="StatusUpdateBrush" Color="#8764B8" />
            <SolidColorBrush x:Key="StatusErrorBrush" Color="#D13438" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
