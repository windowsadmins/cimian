<Project>
  <!--
    Fix CS0579 duplicate assembly attribute errors during solution builds.
    
    Directory.Build.props sets RuntimeIdentifiers=win-x64;win-arm64 for all projects,
    which causes MSBuild to perform inner builds per RID. For WPF (WinExe) and test
    projects, the inner builds each generate AssemblyInfo.cs files that collide during
    compilation, producing CS0579 errors.
    
    Fix: Disable auto-generated assembly attributes for these project types.
    The actual RID-specific binary is produced via dotnet publish -r <rid> in build.ps1.
  -->
  <PropertyGroup Condition="'$(OutputType)' == 'WinExe' OR '$(IsTestProject)' == 'true'">
    <GenerateAssemblyInfo>false</GenerateAssemblyInfo>
    <GenerateTargetFrameworkAttribute>false</GenerateTargetFrameworkAttribute>
  </PropertyGroup>
</Project>
